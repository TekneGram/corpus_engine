#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  echo "[commit-msg] Missing commit message file." >&2
  exit 1
fi

FIRST_LINE="$(head -n 1 "$MSG_FILE")"

# Enforce: type: summary
# Examples: feat: add semantic binary postings, fix: handle grep fallback
if ! printf '%s' "$FIRST_LINE" | grep -Eq '^[a-z]+: .+'; then
  cat >&2 <<'EOF'
[commit-msg] Invalid commit message format.
Expected: type: summary
Examples:
  feat: add semantic filter binaries
  fix: fallback to grep in dependency checks
EOF
  exit 1
fi
